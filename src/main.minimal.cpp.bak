// (config_start_portal is in config.cpp)

// ── WiFi ────────────────────────────────────────────────────────
#define WIFI_AP_SSID "ModbusMQTT-Setup"
#define WIFI_AP_PASS "12345678"
#define WIFICFG_APSTA 0

void setup() {
    disableCore0WDT();
    disableCore1WDT();
    
    Serial.begin(115200);
    delay(500);
    Serial.println("\n=== Modbus-MQTT Bridge — MINIMAL+CONFIG+WEB ===");
    
    config_init();
    config_load();
    
    // WiFi AP — mode FIRST, then softAP
    String ap_name = String(WIFI_AP_SSID) + "-" + String((uint32_t)ESP.getEfuseMac(), HEX);
    WiFi.mode(WIFI_AP);
    bool ok = WiFi.softAP(ap_name.c_str(), WIFI_AP_PASS);
    Serial.printf("[WiFi] AP: %s  IP: %s  ok=%s\n", 
        ap_name.c_str(), WiFi.softAPIP().toString().c_str(), ok?"YES":"NO");
    
    // AP+STA mode switch: must re-softAP after mode change!
    if (cfg.wifi_mode == WIFICFG_APSTA && strlen(cfg.wifi_ssid) > 0) {
        WiFi.mode(WIFI_AP_STA);
        WiFi.softAP(ap_name.c_str(), WIFI_AP_PASS);
        WiFi.begin(cfg.wifi_ssid, cfg.wifi_pass);
        Serial.printf("[WiFi] STA connecting to %s\n", cfg.wifi_ssid);
    }
    
    net_connected = (WiFi.status() == WL_CONNECTED || WiFi.softAPIP() != IPAddress(0,0,0,0));
    active_ip = WiFi.softAPIP().toString();
    
    // Web server
    web_server_init();
    Serial.println("[SETUP] ✓ Web server running!");
    
    enableCore0WDT();
}

void loop() {
    web_server_loop();
    delay(2);
}